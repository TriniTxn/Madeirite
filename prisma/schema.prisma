datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Cliente {
  id       Int       @id @default(autoincrement())
  nome     String
  telefone String?
  projetos Projeto[]
}

model Projeto {
  id          Int             @id @default(autoincrement())
  nome        String
  status      String          @default("Em Produção")
  fotoUrl     String?   
  dataEntrega DateTime
  anotacoes   String?
  cliente     Cliente         @relation(fields: [clienteId], references: [id])
  clienteId   Int
  itens       ChecklistItem[]
  criadoEm    DateTime        @default(now())
}

model ChecklistItem {
  id          Int     @id @default(autoincrement())
  titulo      String
  feito       Boolean @default(false)
  concluidoEm DateTime? @updatedAt
  ordem       Int
  projeto     Projeto @relation(fields: [projetoId], references: [id])
  projetoId   Int
}

model Material {
  id         Int    @id @default(autoincrement())
  nome       String
  categoria  String @default("Geral")
  unidade    String
  quantidade Float
  minimo     Float
}